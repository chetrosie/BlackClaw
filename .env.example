PORT=8787
HOST=0.0.0.0
BASE_URL=http://localhost:8787

# mock | stripe
WEBHOOK_MODE=mock

# use this value in header x-mock-signature for /api/webhooks/stripe when WEBHOOK_MODE=mock
STRIPE_WEBHOOK_SECRET=dev_webhook_secret

# required when WEBHOOK_MODE=stripe
STRIPE_SIGNING_SECRET=
STRIPE_TOLERANCE_SEC=300

INSTANCE_DOMAIN=blackclaw.internal
MOCK_PROVISION_DELAY_MS=3000
WORKER_INTERVAL_MS=2000

# json | postgres
DB_DRIVER=json
DB_FILE=./data/db.json
DATABASE_URL=
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# mock | http
PROVIDER_DRIVER=mock
PROVIDER_HTTP_BASE_URL=
PROVIDER_HTTP_API_KEY=
PROVIDER_HTTP_TIMEOUT_MS=5000
